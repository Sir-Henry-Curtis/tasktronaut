{
	"name": "tasktronaut",
	"displayName": "Tasktronaut",
	"description": "Mission-ready coding assistant for structured engineering workflows, with file editing, terminal execution, controlled URL fetch, and human approval gates built into VS Code.",
	"version": "1.2.32",
	"icon": "assets/icons/icon.png",
	"workspaces": [
		".",
		"cli"
	],
	"engines": {
		"vscode": "^1.84.0"
	},
	"author": {
		"name": "Tasktronaut"
	},
	"license": "Apache-2.0 AND MIT",
	"publisher": "tasktronaut",
	"repository": {
		"type": "git",
		"url": "https://git.sethlans.io/jlbrian7/tasktronaut"
	},
	"keywords": [
		"tasktronaut",
		"gsd",
		"nasa",
		"claude",
		"dev",
		"mcp",
		"openrouter",
		"coding",
		"agent",
		"autonomous",
		"chatgpt",
		"sonnet",
		"ai",
		"llama"
	],
	"activationEvents": [
		"onLanguage",
		"onUri",
		"onStartupFinished",
		"workspaceContains:evals.env"
	],
	"main": "./dist/extension.js",
	"contributes": {
		"icons": {
			"cline-icon": {
				"description": "tasktronaut",
				"default": {
					"fontPath": "assets/icons/cline-bot.woff",
					"fontCharacter": "\\e900"
				}
			}
		},
		"walkthroughs": [
			{
				"id": "TasktronautWalkthrough",
				"title": "Meet Tasktronaut",
				"description": "Tasktronaut combines agentic coding with structured execution. Here are 5 ways to put it to work:",
				"steps": [
					{
						"id": "welcome",
						"title": "Start with a Goal, Not Just a Prompt",
						"description": "Tell Tasktronaut what you want to achieve. It plans, explores, and then executes with you in the loop.",
						"media": {
							"markdown": "walkthrough/step1.md"
						}
					},
					{
						"id": "learn",
						"title": "Give It The Right Context",
						"description": "Point Tasktronaut at your project and planning artifacts so it can make context-aware changes.",
						"media": {
							"markdown": "walkthrough/step2.md"
						}
					},
					{
						"id": "advanced-features",
						"title": "Configure The Right Provider",
						"description": "Connect Tasktronaut to the approved provider and model configuration for your environment.",
						"media": {
							"markdown": "walkthrough/step3.md"
						}
					},
					{
						"id": "mcp",
						"title": "Extend With Controlled Tools",
						"description": "Connect Tasktronaut to MCP servers and internal tools without losing operational control.",
						"media": {
							"markdown": "walkthrough/step4.md"
						}
					},
					{
						"id": "getting-started",
						"title": "You're Always in Control",
						"description": "Review Tasktronaut's plans and diffs. Approve changes before they happen. No surprises.",
						"media": {
							"markdown": "walkthrough/step5.md"
						},
						"content": {
							"path": "walkthrough/step5.md"
						}
					}
				]
			}
		],
		"viewsContainers": {
			"activitybar": [
				{
					"id": "tasktronaut-ActivityBar",
					"title": "Tasktronaut",
					"icon": "assets/icons/icon.svg"
				}
			]
		},
		"views": {
			"tasktronaut-ActivityBar": [
				{
					"type": "webview",
					"id": "tasktronaut.SidebarProvider",
					"name": "",
					"icon": "assets/icons/icon.svg"
				}
			]
		},
		"commands": [
			{
				"command": "tasktronaut.plusButtonClicked",
				"title": "New Task",
				"icon": "$(add)"
			},
			{
				"command": "tasktronaut.mcpButtonClicked",
				"title": "MCP Servers",
				"icon": "$(server)"
			},
			{
				"command": "tasktronaut.historyButtonClicked",
				"title": "History",
				"icon": "$(history)"
			},
			{
				"command": "tasktronaut.settingsButtonClicked",
				"title": "Settings",
				"icon": "$(settings-gear)"
			},
			{
				"command": "tasktronaut.gsdButtonClicked",
				"title": "GSD Workflow",
				"icon": "$(checklist)"
			},
			{
				"command": "tasktronaut.gsd.toggleAutoMode",
				"title": "GSD: Toggle Auto Mode",
				"category": "GSD",
				"icon": "$(sync)"
			},
			{
				"command": "tasktronaut.gsd.verifyManagedAssets",
				"title": "GSD: Verify Managed Assets",
				"category": "GSD",
				"icon": "$(verified)"
			},
			{
				"command": "tasktronaut.dev.createTestTasks",
				"title": "Create Test Tasks",
				"category": "Tasktronaut",
				"when": "tasktronaut.isDevMode"
			},
			{
				"command": "tasktronaut.dev.expireMcpOAuthTokens",
				"title": "Expire MCP OAuth Tokens (for testing)",
				"category": "Tasktronaut",
				"when": "tasktronaut.isDevMode"
			},
			{
				"command": "tasktronaut.addToChat",
				"title": "Add to Tasktronaut",
				"category": "Tasktronaut"
			},
			{
				"command": "tasktronaut.focusChatInput",
				"title": "Jump to Chat Input",
				"category": "Tasktronaut"
			},
			{
				"command": "tasktronaut.generateGitCommitMessage",
				"title": "Generate Commit Message with Tasktronaut",
				"category": "Tasktronaut",
				"icon": "$(cline-icon)"
			},
			{
				"command": "tasktronaut.abortGitCommitMessage",
				"title": "Generate Commit Message with Tasktronaut - Stop",
				"category": "Tasktronaut",
				"icon": "$(debug-stop)"
			},
			{
				"command": "tasktronaut.explainCode",
				"title": "Explain with Tasktronaut",
				"category": "Tasktronaut"
			},
			{
				"command": "tasktronaut.improveCode",
				"title": "Improve with Tasktronaut",
				"category": "Tasktronaut"
			},
			{
				"command": "tasktronaut.jupyterGenerateCell",
				"title": "Generate Jupyter Cell with Tasktronaut",
				"category": "Tasktronaut",
				"icon": "$(sparkle)"
			},
			{
				"command": "tasktronaut.jupyterExplainCell",
				"title": "Explain Jupyter Cell with Tasktronaut",
				"category": "Tasktronaut",
				"icon": "$(question)"
			},
			{
				"command": "tasktronaut.jupyterImproveCell",
				"title": "Improve Jupyter Cell with Tasktronaut",
				"category": "Tasktronaut",
				"icon": "$(lightbulb)"
			},
			{
				"command": "tasktronaut.openWalkthrough",
				"title": "Open Tasktronaut Tour",
				"category": "Tasktronaut"
			},
			{
				"command": "tasktronaut.reconstructTaskHistory",
				"title": "Reconstruct Task History",
				"category": "Tasktronaut"
			},
			{
				"command": "tasktronaut.reviewComment.reply",
				"title": "Reply",
				"category": "Tasktronaut",
				"enablement": "!commentIsEmpty"
			},
			{
				"command": "tasktronaut.reviewComment.addToChat",
				"title": "Add to Tasktronaut Chat",
				"category": "Tasktronaut",
				"icon": "$(link-external)"
			}
		],
		"keybindings": [
			{
				"command": "editor.action.submitComment",
				"key": "enter",
				"when": "commentEditorFocused && commentController == tasktronaut-ai-review && !commentIsEmpty"
			},
			{
				"command": "tasktronaut.addToChat",
				"key": "cmd+'",
				"mac": "cmd+'",
				"win": "ctrl+'",
				"linux": "ctrl+'",
				"when": "editorHasSelection"
			},
			{
				"command": "tasktronaut.generateGitCommitMessage",
				"when": "config.git.enabled && scmProvider == git"
			},
			{
				"command": "tasktronaut.focusChatInput",
				"key": "cmd+'",
				"mac": "cmd+'",
				"win": "ctrl+'",
				"linux": "ctrl+'",
				"when": "!editorHasSelection"
			}
		],
		"menus": {
			"view/title": [
				{
					"command": "tasktronaut.plusButtonClicked",
					"group": "navigation@1",
					"when": "view == tasktronaut.SidebarProvider"
				},
				{
					"command": "tasktronaut.mcpButtonClicked",
					"group": "navigation@2",
					"when": "view == tasktronaut.SidebarProvider"
				},
				{
					"command": "tasktronaut.historyButtonClicked",
					"group": "navigation@3",
					"when": "view == tasktronaut.SidebarProvider"
				},
				{
					"command": "tasktronaut.settingsButtonClicked",
					"group": "navigation@6",
					"when": "view == tasktronaut.SidebarProvider"
				},
				{
					"command": "tasktronaut.gsdButtonClicked",
					"group": "navigation@7",
					"when": "view == tasktronaut.SidebarProvider"
				}
			],
			"editor/context": [
				{
					"command": "tasktronaut.addToChat",
					"group": "navigation",
					"when": "editorHasSelection"
				}
			],
			"scm/title": [
				{
					"command": "tasktronaut.generateGitCommitMessage",
					"group": "navigation",
					"when": "config.git.enabled && scmProvider == git && !tasktronaut.isGeneratingCommit"
				},
				{
					"command": "tasktronaut.abortGitCommitMessage",
					"group": "navigation",
					"when": "config.git.enabled && scmProvider == git && tasktronaut.isGeneratingCommit"
				}
			],
			"notebook/toolbar": [
				{
					"command": "tasktronaut.jupyterGenerateCell",
					"group": "navigation/add@1",
					"when": "notebookType == 'jupyter-notebook'"
				}
			],
			"notebook/cell/title": [
				{
					"command": "tasktronaut.jupyterExplainCell",
					"group": "inline@1",
					"when": "notebookType == 'jupyter-notebook'"
				},
				{
					"command": "tasktronaut.jupyterImproveCell",
					"group": "inline@2",
					"when": "notebookType == 'jupyter-notebook'"
				}
			],
			"commandPalette": [
				{
					"command": "tasktronaut.generateGitCommitMessage",
					"when": "config.git.enabled && !tasktronaut.isGeneratingCommit"
				},
				{
					"command": "tasktronaut.abortGitCommitMessage",
					"when": "config.git.enabled && tasktronaut.isGeneratingCommit"
				},
				{
					"command": "tasktronaut.reviewComment.reply",
					"when": "false"
				}
			],
			"comments/commentThread/context": [
				{
					"command": "tasktronaut.reviewComment.reply",
					"group": "inline",
					"when": "commentController == tasktronaut-ai-review"
				}
			],
			"comments/commentThread/title": [
				{
					"command": "tasktronaut.reviewComment.addToChat",
					"group": "inline",
					"when": "commentController == tasktronaut-ai-review"
				}
			]
		},
		"configuration": {
			"title": "Tasktronaut",
			"properties": {}
		}
	},
	"scripts": {
		"vscode:prepublish": "npm run package",
		"compile": "npm run check-types && npm run lint && node esbuild.mjs",
		"compile-standalone": "npm run check-types && npm run lint && node esbuild.mjs --standalone",
		"compile-standalone-npm": "npm run protos && npm run check-types && npm run lint && node esbuild.mjs --standalone",
		"cli:link": "cd cli && npm run link",
		"cli:build": "npm run protos && cd cli && npm run build",
		"cli:run": "node cli/dist/cli.mjs",
		"cli:build:production": "cd cli && npm run build:production",
		"cli:watch": "cd cli && npm run watch",
		"cli:test": "cd cli && npm run test",
		"test:install": "bash scripts/test-install.sh",
		"cli:dev": "cd cli && npm run dev",
		"postcompile-standalone": "node scripts/package-standalone.mjs",
		"postcompile-standalone-npm": "node scripts/package-npm.mjs",
		"dev": "npm run protos && npm run watch",
		"watch": "npx npm-run-all -p watch:*",
		"watch:esbuild": "node esbuild.mjs --watch",
		"watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
		"package": "npm run check:gsd-sdk-shim && npm run check-types && npm run build:webview && npm run lint && node esbuild.mjs --production",
		"prevscode:prepublish": "rm -f dist/*.vsix",
		"protos": "node scripts/build-proto.mjs",
		"protos-python": "node scripts/build-python-proto.mjs",
		"download-ripgrep": "node scripts/download-ripgrep.mjs",
		"postprotos": "biome format src/shared/proto src/core/controller src/hosts/ webview-ui/src/services src/generated --write --no-errors-on-unmatched",
		"clean:build": "rimraf dist dist-standalone webview-ui/build src/generated out/",
		"clean:deps": "rimraf node_modules webview-ui/node_modules",
		"clean:all": "npm run clean:build && npm run clean:deps",
		"compile-tests": "node ./scripts/build-tests.js",
		"watch-tests": "tsc -p . -w --outDir out",
		"check-types": "npm run protos && npx tsc --noEmit && cd webview-ui && npx tsc --noEmit && cd ../cli && npx tsc --noEmit",
		"check:gsd-sdk-shim": "node scripts/check-gsd-sdk-shim.cjs",
		"lint": "biome lint --no-errors-on-unmatched --files-ignore-unknown=true --diagnostic-level=error && npm run lint:proto",
		"lint:proto": "bash ./scripts/proto-lint.sh",
		"format": "biome format --changed --no-errors-on-unmatched --files-ignore-unknown=true --diagnostic-level=error",
		"format:fix": "biome check --changed --no-errors-on-unmatched --files-ignore-unknown=true --write",
		"fix:all": "biome check --no-errors-on-unmatched --files-ignore-unknown=true --write --diagnostic-level=error --unsafe",
		"ci:check-all": "npx npm-run-all -p check-types lint format",
		"ci:build": "npm run protos && npm run build:webview && node esbuild.mjs && npm run compile-tests",
		"pretest": "npm run compile && npm run compile-tests && npm run compile-standalone && npm run lint",
		"test": "npx npm-run-all test:unit test:integration",
		"test:integration": "node scripts/prepare-test-workspace.mjs && vscode-test",
		"test:integration:managed-assets:update": "node scripts/prepare-test-workspace.mjs --seed-stale-managed-assets && vscode-test --grep \"repairs stale managed GSD assets during extension activation\" --fail-zero",
		"test:unit": "cross-env TS_NODE_PROJECT=./tsconfig.unit-test.json node ./scripts/run-unit-tests.cjs",
		"test:coverage": "vscode-test --coverage",
		"test:sca-server": "npx tsx watch scripts/test-standalone-core-api-server.ts",
		"test:tp-orchestrator": "npx tsx scripts/testing-platform-orchestrator.ts",
		"e2e": "playwright test -c playwright.config.ts",
		"test:e2e:build": "vsce package --allow-package-secrets sendgrid --out dist/e2e.vsix",
		"test:e2e": "playwright install && npm run test:e2e:build && node src/test/e2e/utils/build.mjs && playwright test",
		"test:e2e:optimal": "npm run test:e2e:build && node src/test/e2e/utils/build.mjs && playwright test",
		"test:e2e:cli:tui": "cd tests/e2e/cli && tui-test",
		"test:e2e:ui": "npx tsx scripts/interactive-playwright.ts",
		"install:all": "npm install && cd webview-ui && npm install",
		"dev:webview": "cd webview-ui && npm run dev",
		"build:webview": "cd webview-ui && npm run build",
		"test:webview": "cd webview-ui && npm run test",
		"publish:marketplace": "vsce publish --allow-package-secrets sendgrid && ovsx publish",
		"publish:marketplace:prerelease": "vsce publish --allow-package-secrets sendgrid --pre-release && ovsx publish --pre-release",
		"publish:marketplace:nightly": "node ./scripts/publish-nightly.mjs",
		"prepare": "npx husky",
		"docs": "cd docs && npm run dev",
		"docs:check-links": "cd docs && npm run check",
		"docs:rename-file": "cd docs && npm run rename",
		"report-issue": "node scripts/report-issue.js",
		"storybook": "cd webview-ui && npm run storybook",
		"cli:unlink": "cd cli && npm run unlink",
		"eval:smoke:build": "npm run cli:build && npm run cli:link",
		"eval:smoke:run": "npx tsx evals/smoke-tests/run-smoke-tests.ts",
		"eval:smoke": "npm run eval:smoke:build && npm run eval:smoke:run",
		"eval:smoke:ci": "npm run eval:smoke:build && npm run eval:smoke:run -- --trials 1 --parallel"
	},
	"lint-staged": {
		"src/shared/storage/state-keys.ts": [
			"node scripts/generate-state-proto.mjs",
			"git add proto/cline/state.proto"
		],
		"*": [
			"biome check --write --staged --no-errors-on-unmatched --files-ignore-unknown=true"
		]
	},
